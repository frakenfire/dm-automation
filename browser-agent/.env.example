GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# Platforms
INSTAGRAM_USER_DATA_DIR=./user_data/instagram
X_USER_DATA_DIR=./user_data/x

# Limits
DAILY_SEND_LIMIT_INSTAGRAM=50
DAILY_SEND_LIMIT_X=50

# Mode: dry-run, assist, auto
DEFAULT_SEND_MODE=dry-run

# Delays (seconds)
IG_MIN_DELAY=90
IG_MAX_DELAY=300
X_MIN_DELAY=60
X_MAX_DELAY=180
DRY_RUN_DELAY_MIN=1
DRY_RUN_DELAY_MAX=3
